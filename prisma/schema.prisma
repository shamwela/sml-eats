datasource db {
  provider             = "mysql"
  url                  = env("DATABASE_URL")
  referentialIntegrity = "prisma"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["referentialIntegrity"]
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  rating      Float
  imageSource String
  imageWidth  Int
  imageHeight Int
  items       Item[]
}

model Item {
  id           String      @id @default(cuid())
  name         String
  slug         String
  path         String
  imageSource  String
  imageWidth   Int
  imageHeight  Int
  description  String
  category     Category    @relation(fields: [categoryId], references: [id])
  basePrice    Float
  options      Option[]
  Restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  restaurantId String?
  categoryId   String
}

model Option {
  id     String  @id @default(cuid())
  name   String
  inputs Input[]
  Item   Item?   @relation(fields: [itemId], references: [id])
  itemId String?
}

model Input {
  id              String  @id @default(cuid())
  name            String
  additionalPrice Float
  Option          Option? @relation(fields: [optionId], references: [id])
  optionId        String?
}

model Category {
  id          String       @id @default(cuid())
  name        String
  imageSource String
  imageWidth  Int
  imageHeight Int
  Restaurant  Restaurant[]
  Item        Item[]
}
